{
  "$schema": "verification-config-v1",
  "thresholds": {
    "accountAgeKickDays": 0,
    "accountAgeSuspectDays": 7,
    "captchaTimeoutMs": 172800000,
    "captchaMaxAttempts": 3,
    "raidJoinWindowMs": 60000,
    "raidJoinThreshold": 10
  },
  "botUsernamePatterns": [
    "^[a-z]+\\d{4,}$",
    "^[A-Z][a-z]+[A-Z][a-z]+\\d+$",
    "^.{1,3}$",
    "^[a-z]{8,}$"
  ],
  "captcha": {
    "mathMinA": 1,
    "mathMaxA": 20,
    "mathMinB": 1,
    "mathMaxB": 20,
    "imageChars": "ABCDEFGHJKMNPQRSTUVWXYZ23456789",
    "imageLength": 6
  }
}
