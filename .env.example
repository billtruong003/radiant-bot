# ============================================================================
# Radiant Tech Sect Bot — environment configuration
# Copy this file to `.env` and fill in real values. NEVER commit `.env`.
# ============================================================================

# --- Discord credentials --------------------------------------------------
# Get these from https://discord.com/developers/applications
# DISCORD_TOKEN: Bot tab → Reset Token → copy
# DISCORD_CLIENT_ID: General Information → Application ID
# DISCORD_GUILD_ID: right-click your server (Developer Mode on) → Copy Server ID
DISCORD_TOKEN=your-bot-token-here
DISCORD_CLIENT_ID=your-application-id-here
DISCORD_GUILD_ID=your-test-guild-id-here

# --- Runtime --------------------------------------------------------------
# NODE_ENV: development | production
# LOG_LEVEL: trace | debug | info | warn | error | fatal
NODE_ENV=development
LOG_LEVEL=debug

# --- Storage (custom WAL + Snapshot) --------------------------------------
# DATA_DIR: where wal.jsonl and snapshot.json live
# SNAPSHOT_INTERVAL_MS: how often the snapshot timer fires (default 1h)
# WAL_FSYNC: true in production (durable, ~5ms/write), false in dev (faster)
DATA_DIR=./data
SNAPSHOT_INTERVAL_MS=3600000
WAL_FSYNC=true

# --- Admin allow-list -----------------------------------------------------
# Comma-separated Discord user IDs that have super-admin commands (no role check).
ADMIN_USER_IDS=

# --- GitHub backup --------------------------------------------------------
# BACKUP_GITHUB_REPO: "username/private-backup-repo"
# BACKUP_GITHUB_TOKEN: GitHub PAT with `repo` scope only (no other perms)
BACKUP_GITHUB_REPO=
BACKUP_GITHUB_TOKEN=

# --- Health check endpoint ------------------------------------------------
# HEALTH_PORT: HTTP port for /health (UptimeRobot probes). Set to 0 to
# disable. Default 0 (dev), set 3030 in production.
HEALTH_PORT=0
