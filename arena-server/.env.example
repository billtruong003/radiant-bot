# Arena server config
ARENA_PORT=2567
ARENA_HOST=0.0.0.0
NODE_ENV=development
LOG_LEVEL=info

# Shared with bot — must be IDENTICAL to bot's .env values
ARENA_TOKEN_SECRET=replace-with-32-byte-hex
ARENA_RESULT_SECRET=replace-with-32-byte-hex

# Where to POST results when match ends
BOT_RESULT_URL=http://localhost:3030/api/arena/result

# Public WebSocket URL returned to bot in /admin/create-room responses.
# Override per environment — billthedev.com is deprecated; pick a VM IP
# or your own subdomain once deploy lands.
ARENA_PUBLIC_WS=ws://localhost:2567

# Limits
MAX_CONCURRENT_ROOMS=5
JOIN_DEADLINE_MS=300000
TURN_DEADLINE_MS=30000
COUNTDOWN_MS=3000
ANIMATION_TIMEOUT_MS=8000
DISCONNECT_GRACE_MS=30000
RESULT_DISPOSE_DELAY_MS=10000
